<?xml version='1.0' encoding='utf-8'?>
<!-- 二重振り子 URDF (Isaac Sim 用に最適化) -->
<!-- CAD出力URDFを元に、Isaac Simで正しく表示されるよう座標系を修正 -->
<!-- メッシュファイル(STL)はmmスケール → scale 0.001 で m に変換 -->
<!-- 振り子はZ軸方向（下向き）に吊り下がり、Y軸周りに回転 -->
<robot name="double_pendulum">

    <!-- ============================== -->
    <!-- 台座 (世界に固定) -->
    <!-- ============================== -->
    <link name="base">
        <inertial>
            <origin xyz="0.0 0.020682775993718396 0.033905297119097316" rpy="0 0 0" />
            <mass value="0.2737801766240988" />
            <inertia ixx="0.00016679533675185336" iyy="0.00027398927678538214" izz="0.0001958750687430902"
                     ixy="0.0" iyz="0.0" ixz="0.0" />
        </inertial>
        <visual name="base_visual">
            <!-- CADのY,Z → IsaacのZ,Y 変換: rpy="-π/2 0 0" で回転 -->
            <origin xyz="0.0 0.0 0.0" rpy="-1.5707963267948966 0.0 0.0" />
            <geometry>
                <mesh filename="meshes/base.stl" scale="0.001 0.001 0.001" />
            </geometry>
        </visual>
        <collision name="base_collision">
            <origin xyz="0.0 0.0 0.0" rpy="-1.5707963267948966 0.0 0.0" />
            <geometry>
                <mesh filename="meshes/base.stl" scale="0.001 0.001 0.001" />
            </geometry>
        </collision>
    </link>

    <!-- ============================== -->
    <!-- 関節1: 台座 → リンク1 (Y軸回転) -->
    <!-- ============================== -->
    <!-- CAD: origin xyz="0 -0.02 0.023" rpy="π/2 0 0" axis Z -->
    <!-- 変換: rpy消去, Y,Zを入れ替え, 軸をYに変更 -->
    <joint name="joint1" type="continuous">
        <origin xyz="0.0 0.023 -0.02" rpy="0 0 0" />
        <parent link="base" />
        <child link="link1" />
        <axis xyz="0 1 0" />
        <dynamics damping="0.005" friction="0.0" />
    </joint>

    <!-- ============================== -->
    <!-- リンク1 (上側の棒) -->
    <!-- ============================== -->
    <link name="link1">
        <inertial>
            <!-- CAD: xyz="0 -0.0955 -0.00626" → 回転後: xyz="0 -0.00626 -0.0955" -->
            <origin xyz="0.0 -0.006259995602085407 -0.0955400368710832" rpy="0 0 0" />
            <mass value="0.09399409199209499" />
            <inertia ixx="0.00029467377914367196" iyy="0.0002976746822149684" izz="1.0510242045380947e-05"
                     ixy="0.0" iyz="0.0" ixz="0.0" />
        </inertial>
        <visual name="link1_visual">
            <!-- CAD visual: xyz="0 -0.023 -0.02" rpy="-π/2 0 0" -->
            <!-- 回転後: xyz="0 -0.02 -0.023", rpy補正を結合 → rpy="-π 0 0" (既存-π/2 + 座標変換-π/2) -->
            <origin xyz="0.0 -0.02 -0.023" rpy="-3.141592653589793 0.0 0.0" />
            <geometry>
                <mesh filename="meshes/link1.stl" scale="0.001 0.001 0.001" />
            </geometry>
        </visual>
        <collision name="link1_collision">
            <origin xyz="0.0 -0.02 -0.023" rpy="-3.141592653589793 0.0 0.0" />
            <geometry>
                <mesh filename="meshes/link1.stl" scale="0.001 0.001 0.001" />
            </geometry>
        </collision>
    </link>

    <!-- ============================== -->
    <!-- 関節2: リンク1 → リンク2 (Y軸回転) -->
    <!-- ============================== -->
    <!-- CAD: origin xyz="0 -0.17 0.02" rpy="0 0 0" axis Z -->
    <!-- 変換: Y,Zを入れ替え, 軸をYに変更 -->
    <joint name="joint2" type="continuous">
        <origin xyz="0.0 0.02 -0.17" rpy="0 0 0" />
        <parent link="link1" />
        <child link="link2" />
        <axis xyz="0 1 0" />
        <dynamics damping="0.005" friction="0.0" />
    </joint>

    <!-- ============================== -->
    <!-- リンク2 (下側の棒) -->
    <!-- ============================== -->
    <link name="link2">
        <inertial>
            <!-- CAD: xyz="0 -0.0899 -0.0075" → 回転後: xyz="0 -0.0075 -0.0899" -->
            <origin xyz="0.0 -0.007499999999999995 -0.08986164433626702" rpy="0 0 0" />
            <mass value="0.08733391541761781" />
            <inertia ixx="0.0002526481818618852" iyy="0.0002575997390773079" izz="8.226579043583588e-06"
                     ixy="0.0" iyz="0.0" ixz="0.0" />
        </inertial>
        <visual name="link2_visual">
            <!-- CAD visual: xyz="0 0.147 -0.04" rpy="-π/2 0 0" -->
            <!-- 回転後: xyz="0 -0.04 0.147", rpy補正を結合 → rpy="-π 0 0" -->
            <origin xyz="0.0 -0.04 0.147" rpy="-3.141592653589793 0.0 0.0" />
            <geometry>
                <mesh filename="meshes/link2.stl" scale="0.001 0.001 0.001" />
            </geometry>
        </visual>
        <collision name="link2_collision">
            <origin xyz="0.0 -0.04 0.147" rpy="-3.141592653589793 0.0 0.0" />
            <geometry>
                <mesh filename="meshes/link2.stl" scale="0.001 0.001 0.001" />
            </geometry>
        </collision>
    </link>

</robot>